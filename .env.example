# VARIABLES DE ENTORNO — DEV-FRONT-DIGITURNO-BALU-DASHBOARD
# Copiar a .env y completar los valores.

# Token de acceso a Mapbox (público por diseño: prefijo NEXT_PUBLIC_).
# Recomendado: restringir por dominio en el dashboard de Mapbox.
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Token maestro de acceso al aplicativo (SOLO servidor: firma la sesión y valida el login).
TOKEN_DIGITURNO_BALU=

# Modo demo: true = datos simulados realistas cuando DATABASE_URL no está configurada.
DEMO_MODE=false

# Conexión directa a Postgres (Supabase Session Pooler) con rol de SOLO LECTURA.
# SOLO servidor. Sobre la vista gestion_turnos.vw_reporte_atenciones_v2 únicamente se ejecutan select.
# Formato: postgresql://<usuario>.<ref-proyecto>:<password>@aws-0-us-east-2.pooler.supabase.com:5432/postgres
DATABASE_URL=
